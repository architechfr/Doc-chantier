# --- Supabase ---
# Tableau de bord Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon
# Clé service_role : SERVEUR UNIQUEMENT, ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role

# Bucket Supabase Storage où sont déposés les documents importés
SUPABASE_STORAGE_BUCKET=documents

# --- OpenAI (analyse documentaire / OCR vision) ---
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
