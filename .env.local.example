# --- Supabase ---
# Tableau de bord Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon
# Clé service_role : SERVEUR UNIQUEMENT, ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role

# Bucket Supabase Storage où sont déposés les documents importés
SUPABASE_STORAGE_BUCKET=documents

# --- Mistral (analyse documentaire / vision Pixtral) — palier gratuit ---
# Clé gratuite : https://console.mistral.ai > API Keys
MISTRAL_API_KEY=...
# Modèle de vision (défaut si absent : pixtral-12b-2409)
MISTRAL_VISION_MODEL=pixtral-12b-2409

# --- Accès réservé (middleware) ---
# E-mails autorisés à ouvrir DocChantier, séparés par des virgules.
DOC_ALLOWED_EMAILS=h.wahsh@cadence-architectes.fr,archi.tech.fr@gmail.com
